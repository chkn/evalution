{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/add-license-headers.mjs\" --hook",
            "statusMessage": "Adding license header"
          }
        ]
      },
      {
        "matcher": "Edit|MultiEdit|Write|Update",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -Eq '\\.(json|tsx?)$'; then npx biome check --write \"$file_path\" || (exit 2 2>/dev/null); fi; }"
          }
        ]
      }
    ]
  }
}
