{
  "name": "evalution",
  "version": "1.0.0",
  "description": "TypeScript AI Prompt Playground - Edit and execute AI prompts with live preview",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "evalution": "./bin/evalution.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:client",
    "build:cli": "tsup src/cli/index.ts src/index.ts --format esm --outDir dist --dts --external typescript --external ai --external fastify --external chokidar --external minimatch --external pino-pretty",
    "build:client": "vite build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node src/cli/index.ts",
    "dev:server:debug": "node --inspect-brk src/cli/index.ts",
    "dev:client": "vite --mode development",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test --config playwright.config.ts",
    "docs": "typedoc"
  },
  "dependencies": {
    "@fastify/static": "^6.12.0",
    "@fastify/websocket": "^8.3.0",
    "@google/genai": "^1.50.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "ai": "^3.4.0",
    "chokidar": "^5.0.0",
    "fastify": "^4.25.0",
    "minimatch": "^10.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-proppy": "^0.1.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.18.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "concurrently": "^9.2.1",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.17",
    "typedoc-rhineai-theme": "^1.2.0",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  },
  "overrides": {
    "@playwright/experimental-ct-core": {
      "vite": {
        "esbuild": "0.25.12"
      }
    }
  },
  "keywords": [
    "ai",
    "prompt",
    "typescript",
    "playground",
    "vercel-ai-sdk"
  ],
  "author": "",
  "license": "MIT"
}
