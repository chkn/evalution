{
  "name": "evalution",
  "version": "1.0.3",
  "description": "TypeScript AI Prompt Playground - Edit and execute AI prompts with live preview",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "evalution": "./bin/evalution.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "LICENSE.addendum",
    "LICENSING.md"
  ],
  "workspaces": [
    "packages/vercel-ai-sdk"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "npm run build:cli && npm run build:client",
    "build:cli": "tsdown",
    "build:client": "vite build",
    "dev": "concurrently 'npm run dev:server' 'npm run dev:client'",
    "dev:server": "node src/cli/index.ts",
    "dev:server:debug": "node --inspect src/cli/index.ts",
    "dev:client": "vite --mode development",
    "typecheck": "concurrently 'tsc --noEmit' 'tsc --noEmit -p tsconfig.client.json' 'tsc --noEmit -p packages/vercel-ai-sdk'",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test --config playwright.config.ts",
    "docs": "typedoc"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "@hono/node-server": "^2.0.4",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": ">=3.4.0",
    "chokidar": "^5.0.0",
    "hono": "^4.12.23",
    "minimatch": "^10.2.4",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "ts-proppy": "0.2.3",
    "typescript": ">=5.3.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@types/node": ">=22.18.0",
    "@types/react": ">=18.2.45",
    "@types/react-dom": ">=18.2.18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "concurrently": "^9.2.1",
    "tsdown": "^0.22.1",
    "typedoc": "^0.28.17",
    "typedoc-rhineai-theme": "^1.2.0",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  },
  "overrides": {
    "@playwright/experimental-ct-core": {
      "vite": {
        "esbuild": "0.25.12"
      }
    }
  },
  "keywords": [
    "ai",
    "prompt",
    "typescript",
    "playground",
    "vercel-ai-sdk"
  ],
  "author": "Alex Corrado <chkn@hey.com>",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chkn/evalution.git"
  }
}
