{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "vitest/globals"]
  },
  // Typecheck everything under src/ except the client (which has its own
  // tsconfig.client.json) and test fixtures. The build emits via tsdown, not
  // this config, so a broad include here only affects `tsc --noEmit`; keeping
  // it broad means files reachable only from the package entry (src/index.ts) —
  // e.g. the SDK adapters — are checked rather than silently skipped.
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/client",
    "src/prompt/file/ts/__fixtures__"
  ]
}
